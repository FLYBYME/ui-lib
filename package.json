{
    "name": "ui-lib",
    "version": "1.0.0",
    "description": "A TypeScript-based UI component library for IDE-like environments.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "test": "NODE_OPTIONS=--experimental-vm-modules jest",
        "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
        "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
        "lint": "eslint src/**/*.ts",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "typescript",
        "ui-library",
        "esm",
        "canvas-llm"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/node": "^20.0.0",
        "jest": "^29.5.0",
        "jest-environment-jsdom": "^29.5.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "tslib": "^2.5.0"
    }
}